{
  "name": "@k8s-sentinel/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sentinel": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "phase0": "tsx src/scripts/phase0-hello.ts",
    "sentinel": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@k8s-sentinel/agent-analyst": "workspace:*",
    "@k8s-sentinel/agent-author": "workspace:*",
    "@k8s-sentinel/agent-collector": "workspace:*",
    "@k8s-sentinel/core": "workspace:*",
    "@k8s-sentinel/engine-claude": "workspace:*",
    "@k8s-sentinel/engine-hermes": "workspace:*",
    "@k8s-sentinel/tools-mcp": "workspace:*",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
