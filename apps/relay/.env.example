# K8s Sentinel — relay env (Phase 5, hybrid mode). Deploys to Fly.io.
#
# The relay is a stateless forwarder: it persists NO posture payloads. It
# terminates the agent's outbound mTLS tunnel and the control plane's
# authenticated socket, then routes frames between them.

# Listen port (Fly maps 443 → this). Defaults to 8443 with TLS, else 8080.
PORT=8080

# --- Auth -------------------------------------------------------------------
# Control plane → relay: secret the hosted app presents to the /command bridge.
# MUST equal the control plane's RELAY_CONTROL_SECRET. Generate: openssl rand -hex 32
RELAY_CONTROL_SECRET=

# Relay → control plane: secret used to POST the posture ingest webhook.
# MUST equal the control plane's RELAY_INGEST_SECRET. Generate: openssl rand -hex 32
RELAY_INGEST_SECRET=

# HTTPS base of the hosted control plane (token-exchange + ingest webhook).
CONTROL_PLANE_URL=https://your-control-plane.vercel.app

# --- TLS / mTLS -------------------------------------------------------------
# Server cert/key (PEM paths). With both set the relay terminates TLS itself;
# on Fly you can instead terminate TLS at the edge and leave these unset.
RELAY_TLS_CERT=
RELAY_TLS_KEY=
# CA bundle that signs agent CLIENT certs. When set, the relay requests + binds
# the client cert (mTLS); the cert CN is the clusterId. See deploy/relay/relay-ca.sh
RELAY_CLIENT_CA=

# Evict connections idle longer than this (ms).
RELAY_IDLE_MS=90000
