# K8s Sentinel — hosted control-plane env.

# --- Supabase (1B) ----------------------------------------------------------
# Project URL + keys from the Supabase dashboard (Project Settings → API keys).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SERVER ONLY — never prefix with NEXT_PUBLIC. Modern secret key (sb_secret_…),
# or the legacy service_role key. Bypasses RLS; tenant scoping is in code.
SUPABASE_SECRET_KEY=sb_secret_xxx
# SUPABASE_SERVICE_ROLE_KEY=   # legacy fallback, if you haven't migrated keys

# --- NextAuth (1C) ----------------------------------------------------------
# AUTH_SECRET: generate with `openssl rand -base64 32`
AUTH_SECRET=
# OAuth apps — fill the providers you enable.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=

# --- Relay (fase 2) ---------------------------------------------------------
# Public WS base the install command points the agent at (shown in Connect).
RELAY_URL=wss://relay.k8s-sentinel.example
# HTTPS base of the relay's command bridge (for "Scan now" / ask). Same host.
RELAY_HTTP_URL=https://relay.k8s-sentinel.example
# Shared secret the control plane presents to the relay's /command bridge.
# MUST equal the relay's RELAY_CONTROL_SECRET.
RELAY_CONTROL_SECRET=
# Shared secret the relay presents to POST /api/agent/ingest (posture webhook).
# MUST equal the relay's RELAY_INGEST_SECRET.
RELAY_INGEST_SECRET=

# --- Helm chart (Connect screen) --------------------------------------------
# The single source of truth for the `helm install …` command shown on /connect.
# OCI path WITHOUT the oci:// scheme. Defaults to the repo's GHCR org.
# The Connect screen verifies a Helm chart is actually published here (GHCR) and
# refuses to show a broken command if not — set this to your real chart path.
SENTINEL_CHART_REF=ghcr.io/evanapple83-png/k8s-sentinel
# Chart version/tag to install + verify. Matches deploy/helm/Chart.yaml `version`.
SENTINEL_CHART_VERSION=0.2.0
