# --- Engine selection -------------------------------------------------------
# Which agent engine to use: "claude" (default) or "hermes" (air-gapped).
SENTINEL_ENGINE=claude

# --- Claude Agent SDK (engine-claude) ---------------------------------------
# Direct Anthropic API. Leave provider unset to use this.
ANTHROPIC_API_KEY=

# To keep inference inside a cloud boundary, set one of:
#   CLAUDE_CODE_USE_BEDROCK=1   (uses AWS credentials in the environment)
#   CLAUDE_CODE_USE_VERTEX=1    (uses GCP credentials in the environment)
# CLAUDE_CODE_USE_BEDROCK=
# CLAUDE_CODE_USE_VERTEX=

# Per-role model overrides (sensible defaults baked into each agent spec).
SENTINEL_MODEL_COLLECTOR=claude-haiku-4-5
SENTINEL_MODEL_ANALYST=claude-opus-4-7
SENTINEL_MODEL_AUTHOR=claude-sonnet-4-6

# --- Hermes adapter (engine-hermes, Phase 4, air-gap) -----------------------
# Local OpenAI-compatible endpoint for a self-hosted open-weight model.
HERMES_BASE_URL=http://localhost:8080/v1
HERMES_MODEL=NousResearch/Hermes-4-70B

# --- Runtime ----------------------------------------------------------------
# Read-only kubeconfig is mounted into the execution plane only.
KUBECONFIG=
# SQLite datastore path (MVP). Swap for a Postgres URL later.
SENTINEL_DB_PATH=./data/sentinel.sqlite
API_PORT=8787

# --- Hybrid mode: in-cluster agent → relay (`sentinel agent`) ----------------
# The agent dials OUT to the relay (no inbound port). Required for hybrid.
RELAY_URL=
# First boot: single-use install token from the Connect screen.
SENTINEL_INSTALL_TOKEN=
# On reconnect (once registered) — optional; the mTLS cert usually carries identity.
SENTINEL_CLUSTER_ID=
SENTINEL_CLUSTER_NAME=
# mTLS client material (PEM file paths). Omit on first-boot/token bootstrap.
RELAY_CLIENT_CERT=
RELAY_CLIENT_KEY=
RELAY_CA=
